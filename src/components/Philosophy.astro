---
// src/components/Philosophy.astro
---

<!-- PHILOSOPHY / TESTIMONIALS SECTION -->
<section class="section philosophy-section reveal">
	<div class="philosophy-header">
		<h2 class="section-title text-center">
			<span class="lang-id">Filosofi dari Tepian Narosa</span>
			<span class="lang-en">Philosophy from Tepian Narosa</span>
		</h2>
		<span class="subtitle-text text-center">
			<span class="lang-id">Culture Verse — Harmoni & Warisan Adat</span>
			<span class="lang-en">Culture Verse — Harmony & Customary Heritage</span>
		</span>
	</div>

	<div class="quotes-grid">
		<!-- Quote Card 1: Left -->
		<div class="quote-card-side glass-card">
			<div class="quote-side-header">
				<span class="badge-mini">(KAJANG)</span>
			</div>
			<div class="quote-side-body">
				<h4 class="quote-author">Datuk Bendaharo</h4>
				<p class="quote-role">
					<span class="lang-id">Ketua Adat Kuantan</span>
					<span class="lang-en">Kuantan Customary Chief</span>
				</p>
			</div>
		</div>

		<!-- Quote Card 2: Center (Big Quote) -->
		<div class="quote-card-main glass-card">
			<div class="quote-icon">“</div>
			<blockquote class="main-quote">
				<span class="lang-id">"Kecepatan perahu bukanlah hasil dari kayuhan terkuat satu orang, melainkan irama gotong royong puluhan jiwa yang melebur bersama riak Sungai Kuantan."</span>
				<span class="lang-en">"The speed of the boat is not the result of a single strong rower, but the rhythm of collective collaboration of dozens of souls merging with the ripples of Kuantan River."</span>
			</blockquote>
			<div class="quote-footer">
				<span class="quote-meta">(FILOSOFI)</span>
				<span class="quote-meta">(GOTONG-ROYONG)</span>
				<span class="quote-number">11</span>
			</div>
		</div>

		<!-- Quote Card 3: Right -->
		<div class="quote-card-side bg-image-card">
			<div class="quote-side-header">
				<span class="badge-mini">(ANAK PACU)</span>
			</div>
			<div class="quote-side-body">
				<h4 class="quote-author">Rian Hidayat</h4>
				<p class="quote-role">
					<span class="lang-id">Pendayung Haluan</span>
					<span class="lang-en">Bow Rower</span>
				</p>
			</div>
		</div>
	</div>

	<div class="quotes-controls">
		<button class="circular-arrow-btn reverse-arrow" aria-label="Kutipan Sebelumnya / Previous Quote" title="Sebelumnya / Previous">
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
		</button>
		<button class="circular-arrow-btn" aria-label="Kutipan Selanjutnya / Next Quote" title="Selanjutnya / Next">
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
		</button>
	</div>
</section>
