---
// src/components/Hero.astro
---

<!-- Navigation -->
<header class="navbar">
	<div class="nav-container">
		<a href="#" class="logo" aria-label="PacuJalur Home">pacujalur<span>.</span></a>
		
		<div class="nav-middle">
			<span class="live-indicator"></span>
			<span id="local-time" class="time-display">00:00:00 WIB</span>
			<span class="time-label">• Kuantan Singingi</span>
		</div>

		<div class="nav-actions">
			<!-- Bilingual Toggle -->
			<div class="lang-toggle-wrapper">
				<div class="lang-slider"></div>
				<button class="lang-btn active" data-lang-target="id" aria-label="Ubah bahasa ke Indonesia" title="Bahasa Indonesia">ID</button>
				<button class="lang-btn" data-lang-target="en" aria-label="Change language to English" title="English Language">EN</button>
			</div>
			
			<!-- Action Buttons -->
			<a href="#benefits" class="action-btn" aria-label="Dampak & Manfaat Pelestarian" title="Dampak & Manfaat Pelestarian">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
			</a>
		</div>
	</div>
</header>

<!-- HERO SECTION -->
<section class="hero-section">
	<div class="hero-image-container">
		<div class="hero-image-wrapper">
			<img src="/images/hero.png" alt="Pacu Jalur Festival" class="hero-img" />
			<div class="hero-overlay"></div>
		</div>
	</div>
	
	<div class="hero-content">
		<div class="hero-tag-container">
			<span class="hero-tag-line"></span>
			<div class="hero-tag">
				<span class="lang-id">Portal Digital Warisan Budaya Riau</span>
				<span class="lang-en">Digital Portal for Riau Cultural Heritage</span>
			</div>
		</div>
		
		<h1 class="hero-title">
			<span class="lang-id">Menghubungkan tradisi gotong royong dengan masa depan.</span>
			<span class="lang-en">Connecting the spirit of collaboration with the future.</span>
		</h1>
		
		<div class="hero-buttons">
			<a href="#history" class="btn-primary" aria-label="Pelajari sejarah Pacu Jalur">
				<span class="lang-id">Telusuri Sejarah</span>
				<span class="lang-en">Explore History</span>
				<span class="arrow-circle">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
				</span>
			</a>
		</div>
	</div>

	<!-- Floating Badges -->
	<div class="badge-contact">
		<a href="#subscribe" class="contact-circle">
			<span class="lang-id">Hubungi</span>
			<span class="lang-en">Contact</span>
			<div class="circle-hover-fill"></div>
		</a>
	</div>

	<div class="badge-scroll">
		<a href="#history" class="scroll-circle" aria-label="Scroll Down">
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
		</a>
	</div>

	<!-- Bottom Right Floating Card (Glassmorphism) -->
	<div class="hero-floating-card glass-card">
		<button class="card-close-btn" aria-label="Close card">×</button>
		<!-- Custom SVG Ornament Pucuk Rebung as header -->
		<div class="card-ornament">
			<svg width="40" height="24" viewBox="0 0 40 24" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M20 2L32 18H8L20 2Z" stroke="var(--color-accent-2)" stroke-width="2" stroke-linejoin="round"/>
				<path d="M20 8L26 18H14L20 8Z" fill="var(--color-primary)"/>
				<circle cx="20" cy="18" r="2" fill="var(--color-accent-1)"/>
			</svg>
		</div>
		<p class="card-text">
			<span class="lang-id">PacuJalur menyajikan arsip sejarah, pemetaan peran kru, dan pelestarian alam Batang Kuantan secara digital.</span>
			<span class="lang-en">PacuJalur provides historical archives, crew role mapping, and digital preservation of the Kuantan River.</span>
		</p>
		<div class="card-footer">
			<span class="card-meta">(WARISAN)</span>
			<span class="card-meta">(BUDAYA)</span>
			<span class="card-number">01</span>
		</div>
	</div>
</section>

<script>
	// ponytail: live local time clock (WIB / Kuantan Singingi)
	function updateLocalTime() {
		const timeEl = document.getElementById('local-time');
		if (!timeEl) return;
		
		const options: Intl.DateTimeFormatOptions = {
			timeZone: 'Asia/Jakarta',
			hour12: false,
			hour: '2-digit',
			minute: '2-digit',
			second: '2-digit'
		};
		
		const formatter = new Intl.DateTimeFormat('en-US', options);
		const timeString = formatter.format(new Date());
		timeEl.textContent = `${timeString} WIB`;
	}
	
	setInterval(updateLocalTime, 1000);
	updateLocalTime();

	// ponytail: language switching (ID/EN) with sliding pill effect - localStorage FREE (Rule 5 compliance)
	const langButtons = document.querySelectorAll('.lang-btn');
	const langSlider = document.querySelector('.lang-slider') as HTMLElement;
	
	function updateSlider(activeBtn: HTMLElement) {
		if (!langSlider || !activeBtn) return;
		langSlider.style.width = `${activeBtn.offsetWidth}px`;
		langSlider.style.left = `${activeBtn.offsetLeft}px`;
	}

	langButtons.forEach(btn => {
		btn.addEventListener('click', () => {
			const lang = btn.getAttribute('data-lang-target');
			if (!lang) return;

			// Toggle body language class
			document.body.className = `lang-${lang}`;
			
			// Update buttons active state
			langButtons.forEach(b => b.classList.remove('active'));
			btn.classList.add('active');
			updateSlider(btn as HTMLElement);
		});
	});

	// Default initialization (Indonesian)
	document.body.className = 'lang-id';
	const activeBtn = document.querySelector('.lang-btn[data-lang-target="id"]') as HTMLElement;
	if (activeBtn) {
		langButtons.forEach(b => b.classList.remove('active'));
		activeBtn.classList.add('active');
		setTimeout(() => updateSlider(activeBtn), 100);
	}

	// Update slider on resize
	window.addEventListener('resize', () => {
		const active = document.querySelector('.lang-btn.active') as HTMLElement;
		if (active) updateSlider(active);
	});

	// ponytail: close floating card helper
	const closeCardBtn = document.querySelector('.card-close-btn');
	const floatingCard = document.querySelector('.hero-floating-card') as HTMLElement;
	if (closeCardBtn && floatingCard) {
		closeCardBtn.addEventListener('click', () => {
			floatingCard.style.opacity = '0';
			floatingCard.style.transform = 'translateY(20px) scale(0.95)';
			setTimeout(() => floatingCard.style.display = 'none', 400);
		});
	}
</script>
