---
// src/components/Benefits.astro
---

<!-- DETAILS / IMPACT SECTION -->
<section id="benefits" class="section benefits-section reveal">
	<div class="benefits-header">
		<div class="benefits-badge">
			<span class="lang-id">MANFAAT & DAMPAK STRATEGIS</span>
			<span class="lang-en">BENEFITS & STRATEGIC IMPACT</span>
		</div>
		<h2 class="section-title">
			<span class="lang-id">Melestarikan budaya, memajukan daerah</span>
			<span class="lang-en">Preserving heritage, developing region</span>
		</h2>
	</div>

	<div class="benefits-grid">
		<!-- Card 1: Wide (Top Left) -->
		<div class="benefit-card card-wide glass-card">
			<div class="card-content-wrap">
				<div class="card-header-row">
					<h3 class="card-title">
						<span class="lang-id">Menjaga Ekosistem Hutan & Sungai Kuantan secara Lestari</span>
						<span class="lang-en">Sustaining Kuantan River & Forest Ecosystems</span>
					</h3>
					<!-- Language display icon wrapper -->
					<div class="card-mini-lang">
						<span>ID</span>
						<span>•</span>
						<span>EN</span>
					</div>
				</div>
				
				<div class="card-footer-row">
					<div class="card-tags">
						<span class="card-tag-item">(SDG 15)</span>
						<span class="card-tag-item">(CONSERVATION)</span>
					</div>
					<div class="mini-photo-circle">
						<img src="/images/aerial.png" alt="Pemandangan udara barisan perahu Pacu Jalur berlaga di Sungai Kuantan / Aerial view of Pacu Jalur boats racing on Kuantan River" />
					</div>
				</div>
			</div>
		</div>

		<!-- Card 2: Tall (Right) -->
		<div class="benefit-card card-tall">
			<div class="card-content-wrap">
				<button class="plus-btn" aria-label="Detail Nilai Gotong Royong / Details of Collaboration Value">+</button>
				<div class="card-bottom-info">
					<h3 class="card-title">
						<span class="lang-id">Menanamkan Nilai Gotong Royong pada Generasi Masa Kini</span>
						<span class="lang-en">Instilling Mutual Cooperation in the Modern Youth</span>
					</h3>
					<div class="card-tags">
						<span class="card-tag-item">(SDG 11)</span>
						<span class="card-tag-item">(HERITAGE)</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Card 3: Bottom Left 1 -->
		<div class="benefit-card card-square glass-card">
			<div class="card-content-wrap">
				<a href="#subscribe" class="arrow-btn-card" aria-label="Dukungan Ekonomi & Pariwisata / Support Economy & Tourism">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
				</a>
				<div class="card-bottom-info">
					<h3 class="card-title">
						<span class="lang-id">Revitalisasi Ekonomi Kreatif & Pariwisata Tepian Narosa</span>
						<span class="lang-en">Revitalizing Creative Economy & Tourism in Tepian Narosa</span>
					</h3>
					<div class="card-tags">
						<span class="card-tag-item">(SDG 8)</span>
						<span class="card-tag-item">(LOCAL ECONOMY)</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Card 4: Bottom Left 2 -->
		<div class="benefit-card card-square glass-card">
			<div class="card-content-wrap">
				<a href="#subscribe" class="arrow-btn-card" aria-label="Dukungan Kohesi Sosial / Support Social Cohesion">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
				</a>
				<div class="card-bottom-info">
					<h3 class="card-title">
						<span class="lang-id">Mendorong Kohesi Sosial & Sportivitas Lintas Komunitas</span>
						<span class="lang-en">Fostering Social Cohesion & Unity Across Communities</span>
					</h3>
					<div class="card-tags">
						<span class="card-tag-item">(SDG 16)</span>
						<span class="card-tag-item">(SOCIAL COHESION)</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
