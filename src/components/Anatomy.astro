---
// src/components/Anatomy.astro
---

<!-- ANATOMY / INTERACTIVE SECTION -->
<section id="anatomy" class="section reveal relative overflow-hidden py-24 px-6 md:px-10 my-16 mx-auto max-w-[1300px] rounded-[40px] border border-[#0C3E3B]/5 bg-[radial-gradient(circle_at_center,rgba(12,62,59,0.02)_0%,rgba(12,62,59,0.07)_100%)]">
	<div class="flex flex-col gap-14 w-full">
		<!-- Section Header -->
		<div class="text-center max-w-[800px] mx-auto">
			<span class="text-xs font-extrabold text-[#C83E4D] tracking-[0.2em] block mb-2 uppercase">(ANATOMI PERAHU)</span>
			<h2 class="text-4xl md:text-[2.75rem] font-extrabold text-[#0C3E3B] leading-tight tracking-tight">
				<span class="lang-id">Anatomi & Filosofi Peran Jalur</span>
				<span class="lang-en">Anatomy & Philosophy of Jalur Roles</span>
			</h2>
			<p class="text-[#5C6B69] text-base md:text-[1.05rem] leading-relaxed mt-4 font-medium">
				<span class="lang-id">Pacu Jalur bukan sekadar balapan; ia adalah simfoni keselarasan peran di atas air. Geser perahu dan klik pin interaktif untuk mempelajari fungsi serta makna mendalam setiap peran:</span>
				<span class="lang-en">Pacu Jalur is not just a race; it is a symphony of role alignment on water. Scroll the boat and click the interactive pins to learn the function and meaning of each role:</span>
			</p>
		</div>

		<!-- Interactive 3D Perspective Boat Viewer Area -->
		<div class="w-full relative boat-interactive-container">
			<!-- Scroll Hint -->
			<div class="flex flex-col items-center gap-2 mb-5 opacity-90 select-none">
				<span class="text-[0.8rem] font-bold text-[#5C6B69] tracking-wider uppercase">
					<span class="lang-id">← Geser secara horizontal untuk melihat seluruh perahu (25-30 Meter) →</span>
					<span class="lang-en">← Scroll horizontally to see the entire boat (25-30 Meters) →</span>
				</span>
				<div class="w-[120px] h-[3px] bg-[#0C3E3B]/10 rounded-full overflow-hidden relative">
					<div class="absolute left-0 top-0 h-full w-[30%] bg-[#E5A93B] rounded-full transition-all duration-100 scroll-progress"></div>
				</div>
			</div>

			<!-- Widescreen Viewer Frame - Heights and widths perfectly matched with relative parent to resolve Panzoom containment lock -->
			<div class="w-full h-[400px] relative overflow-hidden cursor-grab rounded-2xl bg-white/45 border border-white/50 backdrop-blur-md shadow-[inset_0_2px_10px_rgba(12,62,59,0.02)] boat-viewer-scroll" id="boatViewerScroll">
				<div class="w-[1600px] h-[400px] boat-perspective-wrapper" id="boatPerspective">
					<div class="relative w-[1600px] h-[400px] boat-canvas-container">
						<!-- Detailed SVG Boat Illustration -->
						<svg class="w-full h-full block select-none pointer-events-none" viewBox="0 0 1600 400" xmlns="http://www.w3.org/2000/svg">
							<defs>
								<!-- Boat Wood Gradient -->
								<linearGradient id="boat-wood" x1="0%" y1="50%" x2="100%" y2="50%">
									<stop offset="0%" stop-color="#5a381d" />
									<stop offset="25%" stop-color="#8c5830" />
									<stop offset="50%" stop-color="#a46d3e" />
									<stop offset="75%" stop-color="#8c5830" />
									<stop offset="100%" stop-color="#5a381d" />
								</linearGradient>
								
								<!-- Gold Decoration Gradient -->
								<linearGradient id="gold-ornament" x1="0%" y1="0%" x2="100%" y2="100%">
									<stop offset="0%" stop-color="#E5A93B" />
									<stop offset="50%" stop-color="#FFF3CD" />
									<stop offset="100%" stop-color="#B87D1B" />
								</linearGradient>

								<!-- Water Ripples Gradient -->
								<linearGradient id="water-grad" x1="0%" y1="0%" x2="0%" y2="100%">
									<stop offset="0%" stop-color="rgba(12, 62, 59, 0.4)" />
									<stop offset="50%" stop-color="rgba(12, 62, 59, 0.7)" />
									<stop offset="100%" stop-color="rgba(12, 62, 59, 0.95)" />
								</linearGradient>

								<!-- Shadow Filter -->
								<filter id="drop-shadow" x="-10%" y="-10%" width="120%" height="120%">
									<feDropShadow dx="0" dy="12" stdDeviation="8" flood-color="#051413" flood-opacity="0.35" />
								</filter>
							</defs>

							<!-- RIVER WATER BACKGROUND & WAVES -->
							<g>
								<path d="M 0,260 C 200,240 400,280 600,260 C 800,240 1000,280 1200,260 C 1400,240 1600,280 1600,260 L 1600,400 L 0,400 Z" fill="url(#water-grad)" opacity="0.6" />
								<path d="M 0,280 C 300,300 600,260 900,280 C 1200,300 1500,260 1600,270 L 1600,400 L 0,400 Z" fill="#0C3E3B" opacity="0.9" />
								<path d="M 0,310 C 150,295 300,325 450,310 C 600,295 750,325 900,310 C 1050,295 1200,325 1350,310 C 1500,295 1600,310 1600,310 L 1600,400 L 0,400 Z" fill="rgba(229, 169, 59, 0.15)" />
							</g>

							<!-- MAIN BOAT STRUCTURE (JALUR) -->
							<g filter="url(#drop-shadow)">
								<!-- The Long Sleek Hull -->
								<path d="M 80,140 
										 C 85,150 95,190 120,210 
										 C 160,240 400,250 800,250 
										 C 1200,250 1440,240 1480,210 
										 C 1505,190 1515,150 1520,120
										 C 1520,120 1530,95 1515,90
										 C 1500,85 1475,170 1440,205
										 C 1400,225 1200,230 800,230
										 C 400,230 200,225 160,205
										 C 125,170 100,85 85,90
										 C 70,95 80,140 80,140 Z" 
									  fill="url(#boat-wood)" id="boatHullShape" />

