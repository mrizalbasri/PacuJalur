				<!-- Bouncing wave ripples representing kinetic body weight motion -->
				<path d="M 25,45 C 35,35 45,55 55,45 C 65,35 75,55 75,55" stroke="#0C3E3B" stroke-width="4.5" stroke-linecap="round" fill="none" />
				<path d="M 25,60 C 35,50 45,70 55,60 C 65,50 75,70 75,70" stroke="#C83E4D" stroke-width="4.5" stroke-linecap="round" fill="none" />
