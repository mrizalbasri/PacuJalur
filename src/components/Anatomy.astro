	// DOM Elements Selection
	const hotspots = document.querySelectorAll('.hotspot-pin');
	const roleTabs = document.querySelectorAll('.role-tab');
	const cardWatermark = document.getElementById('cardWatermark');
	const cardRoleType = document.getElementById('cardRoleType');
	const cardRoleTitle = document.getElementById('cardRoleTitle');
	const cardDescBody = document.getElementById('cardDescBody');
	const roleVectorBadge = document.getElementById('roleVectorBadge');
	
	const boatViewerScroll = document.getElementById('boatViewerScroll');
	const boatPerspective = document.getElementById('boatPerspective');
	const scrollProgress = document.querySelector('.scroll-progress');

	// Active role state
	let activeRole = 'tari';

	// Function to update the information board
	function selectRole(roleId) {
		if (!roleDatabase[roleId]) return;
		activeRole = roleId;
		const data = roleDatabase[roleId];

		// Update watermarks and text headers
		if (cardWatermark) cardWatermark.textContent = data.num;
		
		// Set bilingual title
		if (cardRoleTitle) {
			cardRoleTitle.innerHTML = `
				<span class="lang-id">${data.title.id}</span>
				<span class="lang-en">${data.title.en}</span>
			`;
		}

		// Set bilingual category label
		if (cardRoleType) {
			cardRoleType.innerHTML = `
				<span class="lang-id">${data.type.id}</span>
				<span class="lang-en">${data.type.en}</span>
			`;
		}

		// Set bilingual description
		if (cardDescBody) {
			cardDescBody.innerHTML = `
				<div class="lang-id">${data.desc.id}</div>
				<div class="lang-en">${data.desc.en}</div>
			`;
		}

		// Inject SVG illustration into badge
		if (roleVectorBadge) {
			roleVectorBadge.innerHTML = data.badge;
		}

		// 1. Update Active Tab styling (using Tailwind classes directly for clean state)
		roleTabs.forEach(tab => {
			if (tab.getAttribute('data-role') === roleId) {
				tab.classList.add('bg-[#0C3E3B]', 'text-white', 'border-[#0C3E3B]');
				tab.classList.remove('bg-white', 'text-black', 'border-[#0C3E3B]/5');
				
				const numSpan = tab.querySelector('.role-num');
				if (numSpan) {
					numSpan.classList.add('text-[#E5A93B]', 'opacity-100');
					numSpan.classList.remove('opacity-45');
				}
			} else {
				tab.classList.remove('bg-[#0C3E3B]', 'text-white', 'border-[#0C3E3B]');
				tab.classList.add('bg-white', 'text-black', 'border-[#0C3E3B]/5');
				
				const numSpan = tab.querySelector('.role-num');
				if (numSpan) {
					numSpan.classList.remove('text-[#E5A93B]', 'opacity-100');
					numSpan.classList.add('opacity-45');
				}
			}
		});

		// 2. Update Active hotspot styling (using Tailwind classes directly for clean state)
		hotspots.forEach(hotspot => {
			if (hotspot.getAttribute('data-pin') === roleId) {
				hotspot.classList.add('active', 'scale-110', 'bg-[#C83E4D]', 'ring-4', 'ring-[#C83E4D]/30');
				hotspot.classList.remove('bg-[#0C3E3B]');
				
				// Run centering with error protection
				try {
					centerHotspotInView(hotspot);
				} catch (err) {
					console.error("Failed to center hotspot:", err);
				}
			} else {
				hotspot.classList.remove('active', 'scale-110', 'bg-[#C83E4D]', 'ring-4', 'ring-[#C83E4D]/30');
				hotspot.classList.add('bg-[#0C3E3B]');
			}
		});

		// 3. Trigger card transition animation
		const card = document.querySelector('.anatomy-content-card');
		if (card) {
			card.style.transform = 'scale(0.98)';
			card.style.opacity = '0.7';
			setTimeout(() => {
				card.style.transform = 'scale(1)';
				card.style.opacity = '1';
			}, 100);
		}
	}

	// Helper to center active hotspot horizontally using Panzoom
	function centerHotspotInView(hotspotElement) {
		if (!panzoomInstance || !hotspotElement) return;
		
		const viewerRect = boatViewerScroll.getBoundingClientRect();
		const hotspotLeft = hotspotElement.offsetLeft;
		
		// Target X to center the hotspot
		const targetX = (viewerRect.width / 2) - hotspotLeft;
		
		// Pan smoothly to the target X coordinate
		panzoomInstance.pan(targetX, 0, { animate: true });
	}

	// Add event listeners to Hotspot Pins
	hotspots.forEach(pin => {
		pin.addEventListener('click', () => {
			const roleId = pin.getAttribute('data-pin');
			if (roleId) selectRole(roleId);
		});
	});

	// Add event listeners to Selector Tabs
	roleTabs.forEach(tab => {
		tab.addEventListener('click', () => {
			const roleId = tab.getAttribute('data-role');
			if (roleId) selectRole(roleId);
		});
	});



	// 2. PANZOOM FOR SMOOTH DRAG & ZOOM
	let panzoomInstance;
	if (boatPerspective && boatViewerScroll) {
		panzoomInstance = Panzoom(boatPerspective, {
			maxScale: 2.5,
			minScale: 1,
			contain: 'outside',
			cursor: 'grab',
			disableY: true, // Lock vertical panning
			startX: 0,      // Start aligned to the left (bow visible)
		});

		// Enable zooming using mouse wheel (holding Ctrl to avoid scroll trap)
		boatViewerScroll.addEventListener('wheel', (e) => {
			if (e.ctrlKey) {
				e.preventDefault();
				panzoomInstance.zoomWithWheel(e);
			}
		});

		// Sync scroll progress bar on pan/zoom change
		boatPerspective.addEventListener('panzoomchange', () => {
			const pan = panzoomInstance.getPan();
			const scale = panzoomInstance.getScale();
			
			// Calculate the scrollable range width
			const containerWidth = boatViewerScroll.clientWidth;
			const contentWidth = 1600 * scale; // 1600px is the base width of our wrapper
			const maxScroll = contentWidth - containerWidth;
			
			if (maxScroll > 0) {
				// Pan x is negative when dragged to the left
				const currentPanX = Math.abs(pan.x);
				const percentage = Math.min(100, Math.max(0, (currentPanX / maxScroll) * 100));
				scrollProgress.style.width = `${percentage}%`;
			} else {
				scrollProgress.style.width = '0%';
			}
		});
	}

	// Initialize with first role load
	selectRole('tari');
</script>
